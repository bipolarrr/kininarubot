{
  "name": "kininarubot",
  "version": "0.1.0",
  "private": true,
  "description": "A personal Discord music bot for YouTube playback via slash commands.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/wasi-threads": "^1.2.1",
    "@noble/ciphers": "^2.2.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "opusscript": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
